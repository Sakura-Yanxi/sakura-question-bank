PORT=8000
# Local default is safest. On a server, keep this as 127.0.0.1 when using Nginx.
# Set to 0.0.0.0 only if you understand the network/security impact.
SAKURA_HOST=127.0.0.1
APP_PUBLIC_URL=http://127.0.0.1:8000

# Leave blank for local-only use. Set both before public deployment.
SAKURA_ADMIN_PASSWORD=
SAKURA_AUTH_SECRET=

# Demo mode makes mutating API requests read-only.
SAKURA_DEMO_MODE=0

# In-app "new version available" notice. Releases are matched by tag (e.g. v1.1.0).
SAKURA_UPDATE_REPO=Sakura-Yanxi/sakura-question-bank

# Text explanation settings. Used for knowledge explanation, question analysis,
# variants, reflections, and textbook pages that have extractable text.
# Example DeepSeek-compatible setup:
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Optional vision settings. Used for scanned textbook pages, page screenshots,
# and PDFs with no extractable text. DeepSeek-style text chat models cannot read
# these images unless the selected provider/model explicitly supports image input.
# The vision provider may differ from the text model, e.g. text=DeepSeek and
# vision=Qwen-VL / GPT-4o / Doubao Vision. Key/base_url fall back to the text
# settings when left blank, so same-provider setups only need LLM_VISION_MODEL.
LLM_VISION_MODEL=
LLM_VISION_API_KEY=
LLM_VISION_BASE_URL=

# Optional notifications.
WEWORK_BOT_WEBHOOK=
PUSHPLUS_TOKEN=
EMAIL_ENABLED=0
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_USE_STARTTLS=0
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=
EMAIL_FROM=
EMAIL_FROM_NAME=Sakura Study

# Optional reminder defaults.
SAKURA_INTERNAL_SCHEDULER=1
SAKURA_SCHEDULER_POLL_SECONDS=30
REMIND_MORNING_ON=0
REMIND_MORNING_TIME=10:00
REMIND_NIGHT_ON=0
REMIND_NIGHT_TIME=20:00
REMIND_WEATHER_ON=0
REMIND_WEATHER_TIME=22:30
REMIND_CHECKIN_MODE=wework
REMIND_DAILY_SCOPE=due
REMIND_DAILY_LIMIT=20
REMIND_SEND_PDF=1
WEATHER_CITY=Beijing
